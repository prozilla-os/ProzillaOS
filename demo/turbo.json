{
	"$schema": "https://turborepo.dev/schema.json",
	"extends": ["//"],
	"tasks": {
		"fetch": {
			"dependsOn": ["^build"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"build": {
			"dependsOn": ["$TURBO_EXTENDS$", "fetch"],
			"env": ["VITE_NODE"],
			"inputs": ["$TURBO_DEFAULT$", "public/config/tree.json"],
			"outputLogs": "new-only"
		}
	}
}
