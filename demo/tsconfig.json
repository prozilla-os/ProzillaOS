{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"baseUrl": "../",
		"types": ["vite/client", "node", "vite-plugin-svgr/client"],
		"paths": {
			"prozilla-os": ["packages/prozilla-os/src/main"],
			"@prozilla-os/*": ["packages/*/src/main", "packages/apps/*/src/main"],
		}
	},
	"include": [
		"src",
		"vite.config.ts",
		"scripts",
	],
	"exclude": ["node_modules", "**/dist/**"]
}