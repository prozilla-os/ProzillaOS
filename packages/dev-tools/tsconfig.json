{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"baseUrl": "../..",
		"composite": true,
		"outDir": "dist",
		"declaration": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"rootDir": "../",
		"paths": {
			"@prozilla-os/core": ["packages/core/src/main"],
			"@prozilla-os/shared": ["packages/shared/src/main"]
		},
	},
	"include": ["src", "vite.config.ts", "../core/src", "../shared/src"],
	"exclude": ["node_modules"]
}